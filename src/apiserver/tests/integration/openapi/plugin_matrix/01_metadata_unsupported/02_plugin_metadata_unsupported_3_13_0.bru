meta {
  name: plugin_metadata_path_unsupported_3_13_0
  type: http
  seq: 2
}

post {
  url: {{scheme}}://{{host}}/api/v1/open/gateways/bk-apisix-plugin-matrix-313/resources/plugin_metadata/
}

headers {
  Content-Type: application/json
  X-BK-API-TOKEN: {{x_bk_api_token}}
}

body {
  [
    {
      "config": {
        "log_format": {
          "client_ip": "$remote_addr",
          "host": "$host"
        }
      },
      "name": "clickhouse-logger"
    }
  ]
}

assert {
  res.status: eq 400
  res.body.error.code: eq "BadRequest"
}
