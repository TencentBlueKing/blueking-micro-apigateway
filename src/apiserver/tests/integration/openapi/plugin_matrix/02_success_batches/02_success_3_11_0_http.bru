  [
    {
      "config": {
        "labels": {
          "env": "test"
        },
        "methods": [
          "GET"
        ],
        "plugins": {
          "ai-prompt-decorator": {
            "append": [
              {
                "content": "End the response with an analogy.",
                "role": "system"
              }
            ],
            "prepend": [
              {
                "content": "I have exams tomorrow so explain conceptually and briefly",
                "role": "system"
              }
            ]
          }
        },
        "upstream": {
          "nodes": [
            {
              "host": "httpbin.org",
              "port": 80,
              "weight": 1
            }
          ],
          "scheme": "http",
          "type": "roundrobin"
